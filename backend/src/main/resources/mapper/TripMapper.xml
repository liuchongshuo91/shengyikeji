<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.kjd.backend.mapper.TripMapper">

    <!-- 通用查询映射结果 -->
    <resultMap id="BaseResultMap" type="com.kjd.backend.entity.Trip">
        <id column="id" property="id"/>
        <result column="main_id" property="mainId"/>
        <result column="traveler_id" property="travelerId"/>
        <result column="traveler_no" property="travelerNo"/>
        <result column="traveler_name" property="travelerName"/>
        <result column="departure_city_no" property="fromCityNo"/>
        <result column="departure_city" property="fromCityName"/>
        <result column="arriving_city_no" property="toCityNo"/>
        <result column="arriving_city" property="toCityName"/>
        <result column="departure_date" property="startDate"/>
        <result column="arrival_date" property="endDate"/>
        <result column="itinerary_instructions" property="tripDescription"/>
    </resultMap>

    <!-- 根据主表ID查询行程列表 -->
    <select id="selectByMainId" resultMap="BaseResultMap">
        SELECT * FROM fk_reim_itinerary
        WHERE main_id = #{mainId}
        ORDER BY departure_date, id
    </select>

    <!-- 根据主表ID删除行程 -->
    <delete id="deleteByMainId">
        DELETE FROM fk_reim_itinerary WHERE main_id = #{mainId}
    </delete>

</mapper>
