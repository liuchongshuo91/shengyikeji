<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.kjd.backend.mapper.ReimbursementMapper">

    <!-- 通用查询映射结果 -->
    <resultMap id="BaseResultMap" type="com.kjd.backend.entity.Reimbursement">
        <id column="id" property="id"/>
        <result column="reim_no" property="reimbursementNo"/>
        <result column="status" property="status"/>
        <result column="creation_time" property="creationTime"/>
        <result column="submit_date" property="submitDate"/>
        <result column="reimbursement_title" property="reimbursementTitle"/>
        <result column="reimburser_id" property="reimburserId"/>
        <result column="reimburser_no" property="reimburserNo"/>
        <result column="reimburser_name" property="reimburserName"/>
        <result column="reim_department_id" property="reimDepartmentId"/>
        <result column="reim_department_no" property="reimDepartmentNo"/>
        <result column="reim_department_name" property="reimDepartmentName"/>
        <result column="reim_company_id" property="reimCompanyId"/>
        <result column="reim_company_no" property="reimCompanyNo"/>
        <result column="reim_company_name" property="reimCompanyName"/>
        <result column="business_type_id" property="businessTypeId"/>
        <result column="business_type_no" property="businessTypeNo"/>
        <result column="business_type_name" property="businessTypeName"/>
        <result column="business_trip_reason" property="businessTripReason"/>
        <result column="subsidy_total" property="subsidyTotal"/>
        <result column="meal_allowance" property="mealAllowance"/>
        <result column="transportation_allowance" property="transportationAllowance"/>
        <result column="phone_allowance" property="phoneAllowance"/>
        <result column="remarks" property="remarks"/>
        <result column="allocations_json" property="allocations"
                typeHandler="com.baomidou.mybatisplus.extension.handlers.JacksonTypeHandler"/>
    </resultMap>

    <!-- 带详情的结果映射 -->
    <resultMap id="DetailResultMap" type="com.kjd.backend.entity.Reimbursement" extends="BaseResultMap">
        <collection property="trips" column="id" select="com.kjd.backend.mapper.TripMapper.selectByMainId"/>
        <collection property="subsidies" column="id" select="com.kjd.backend.mapper.SubsidyMapper.selectByMainId"/>
    </resultMap>

    <!-- 根据ID查询带详情 -->
    <select id="selectWithDetails" resultMap="DetailResultMap">
        SELECT * FROM fk_reim_main WHERE id = #{id}
    </select>

    <!-- 分页查询 -->
    <select id="selectPageList" resultMap="BaseResultMap">
        SELECT * FROM fk_reim_main
        <where>
            <if test="reimbursementNo != null and reimbursementNo != ''">
                AND reim_no LIKE CONCAT('%', #{reimbursementNo}, '%')
            </if>
            <if test="reimbursementTitle != null and reimbursementTitle != ''">
                AND reimbursement_title LIKE CONCAT('%', #{reimbursementTitle}, '%')
            </if>
            <if test="businessTripReason != null and businessTripReason != ''">
                AND business_trip_reason LIKE CONCAT('%', #{businessTripReason}, '%')
            </if>
            <if test="reimCompanyId != null and reimCompanyId != ''">
                AND reim_company_id = #{reimCompanyId}
            </if>
            <if test="reimDepartmentId != null and reimDepartmentId != ''">
                AND reim_department_id = #{reimDepartmentId}
            </if>
            <if test="reimburserId != null and reimburserId != ''">
                AND reimburser_id = #{reimburserId}
            </if>
            <if test="businessTypeId != null and businessTypeId != ''">
                AND business_type_id = #{businessTypeId}
            </if>
        </where>
        ORDER BY creation_time DESC
    </select>

    <!-- 更新状态 -->
    <update id="updateStatusById">
        UPDATE fk_reim_main SET status = #{status} WHERE id = #{id}
    </update>

</mapper>
